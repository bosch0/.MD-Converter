{
  "name": "md-converter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && vite build --ssr src/entry-server.ts --outDir dist-ssr && node scripts/prerender.mjs",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.1",
    "eslint-plugin-svelte": "^3.12.5",
    "globals": "^16.5.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.3",
    "svelte": "^5.55.4",
    "svelte-check": "^4.4.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.46.2",
    "vitest": "^3.2.4",
    "vite": "7.3.3"
  },
  "dependencies": {
    "dompurify": "^3.3.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.12.0",
    "marked": "^18.0.2",
    "pdfjs-dist": "^5.7.284",
    "turndown": "^7.2.4"
  }
